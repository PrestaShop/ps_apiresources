includes:
    - %currentWorkingDirectory%/tests/PHPStan/phpstan.neon

parameters:
    tmpDir: %currentWorkingDirectory%/var/phpstan-tmp/9.1.x
    ignoreErrors:
        # Add version-specific ignores here as needed
        # The following Shipment domain classes don't exist yet on 9.1.x
        -
            message: "#Class .*CreateShipment.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Order/Shipment.php
        -
            message: "#Class .*AddProductToShipment.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Order/ShipmentProducts.php
        -
            message: "#Class .*GetShipmentsForOrderDetail.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Order/OrderDetailShipments.php
        -
            message: "#Class .*ListAvailableShipmentsForProduct.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Order/AvailableShipmentsForProduct.php
        -
            message: "#Class .*FulfillShipmentCommand.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Shipment/ShipmentFulfillment.php
        -
            message: "#Class .*InvalidShipmentTrackingNumberException.* not found.#"
            identifier: class.notFound
            path: ../../src/ApiPlatform/Resources/Shipment/ShipmentFulfillment.php
